# Base Configuration
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# Database
MONGODB_URI=mongodb://localhost:27017/einsoft-gps
MONGODB_USER=admin
MONGODB_PASSWORD=secure_password

# JWT Security
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# Redis Cache
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# Email Service (Nodemailer)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@einsoftgps.com

# SMS Service (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE=+1234567890

# Mapbox Token
MAPBOX_TOKEN=pk_your_mapbox_token

# AWS S3 (Optional, for reports storage)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_S3_BUCKET=einsoft-gps-reports

# Encryption
ENCRYPTION_KEY=your_encryption_key_32_chars_long

# Socket.io
SOCKET_IO_CORS_ORIGIN=http://localhost:3000

# Admin Credentials (Initial Setup)
ADMIN_EMAIL=admin@einsoftgps.com
ADMIN_PASSWORD=change_this_password
